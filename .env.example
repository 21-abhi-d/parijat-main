# Copy this file to .env and populate with your secrets.
# Keep this file committed and up-to-date when new variables are added.
# Never put real secrets in this file.

# ─── Application ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth.js v5 ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
ADMIN_EMAIL=""
# Generate hash: npx tsx scripts/hash-password.ts <password>
ADMIN_PASSWORD_HASH=""

# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGODB_URI=""

# ─── AWS ───────────────────────────────────────────────────────────────────
# In production use an IAM Role on the compute resource instead of key/secret
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
CLOUDFRONT_URL=""

# ─── Resend ────────────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_ADDRESS=""

# ─── Twilio ────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ─── Cal.com ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALCOM_LINK=""
CALCOM_WEBHOOK_SECRET=""

# ─── Analytics (PostHog — public key is safe to expose) ────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ─── Stripe (placeholder — DO NOT implement yet) ───────────────────────────
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
