# Copy this file to .env and populate with your values.
# Never commit .env — only .env.example is committed.
# When adding new variables, update both this file and src/env.js.

# ── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — create at console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=""

# ── AWS S3 + CloudFront ───────────────────────────────────────────────────────
# In production use an IAM Role on the compute resource instead of key/secret
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
CLOUDFRONT_URL=""

# ── Resend (email notifications) ──────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_ADDRESS=""

# ── Twilio (SMS notifications) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Cal.com ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALCOM_LINK=""
# Optional — only needed if Cal.com webhook mirroring is added later
# CALCOM_WEBHOOK_SECRET=""

# ── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
